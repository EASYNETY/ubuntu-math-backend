# EvriPay Payment Gateway Configuration
# =========================================
# API base URL for EvriPay service
EVRIPAY_API_URL=https://evripay.onrender.com

# Client ID provided by EvriPay (replace with your actual client ID)
EVRIPAY_CLIENT_ID=your_client_id_here

# API Key for authenticating with EvriPay (replace with your actual API key)
EVRIPAY_API_KEY=your_api_key_here

# Webhook secret for verifying webhook signatures (replace with your actual secret)
EVRIPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Database Configuration
# =========================================
# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/ubuntu-math

# JWT Configuration
# =========================================
# Secret key for signing JWT tokens
JWT_SECRET=your_jwt_secret_here

# Frontend URL
# =========================================
# URL of the frontend application (used for CORS)
CLIENT_URL=http://localhost:5173

# Server Port
# =========================================
PORT=5000
